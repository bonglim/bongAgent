# 백엔드 CORS 허용 origin입니다. 프론트 개발 서버 주소를 쉼표로 추가할 수 있습니다.
BACKEND_CORS_ORIGINS=http://localhost:5173

# MVP 기본값은 mock입니다. Gemini와 OpenAI를 모델별로 선택하려면 auto로 설정할 수 있습니다.
LLM_PROVIDER=auto

# 콤보박스 모델 목록과 모델별 provider/key 변수명을 설정합니다.
# 형식: model_id|화면표시명|provider|API_KEY_ENV_NAME;...
# 이 값만 바꾸면 프론트 콤보박스와 백엔드 라우팅이 함께 바뀝니다.
LLM_MODELS=gemini-2.5-flash|gemini-2.5-flash|gemini|GEMINI_API_KEY;gemini-3.5-flash|gemini-3.5-flash|gemini|GEMINI_API_KEY;gpt5.5|gpt5.5|openai|OPENAI_API_KEY;gpt-4o-mini|GPT4o-mini|openai|GPT4O_MINI_API_KEY
DEFAULT_LLM_MODEL=gemini-3.5-flash

# 모델별 key_env에서 참조하는 API 키입니다. 저장소에 커밋하지 말고 로컬 .env에만 관리하세요.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
OPENAI_API_KEY=
GPT4O_MINI_API_KEY=

# 프론트엔드가 호출할 FastAPI 서버 주소입니다.
VITE_API_BASE_URL=http://localhost:8000

# Langfuse 관측성 설정입니다. Project Settings > API Keys에서 발급한 값을 입력하세요.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_TRACING_ENVIRONMENT=development
