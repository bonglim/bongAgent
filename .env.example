# Backend CORS 허용 origin입니다. 프론트 개발 서버 주소를 쉼표로 추가할 수 있습니다.
BACKEND_CORS_ORIGINS=http://localhost:5173

# MVP 기본값은 mock입니다. 실제 GPT 연결 시 gpt 또는 openai로 설정할 수 있습니다.
LLM_PROVIDER=gpt

# 실제 GPT API 연동을 위한 키입니다. 저장소에 커밋하지 말고 로컬 .env에만 관리하세요.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# 프론트엔드가 호출할 FastAPI 서버 주소입니다.
VITE_API_BASE_URL=http://localhost:8000
